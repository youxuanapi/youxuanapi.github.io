### 01_核心库文件（lib/validation.ts）.txt

**操作说明**：**新建** `lib/validation.ts`，用以下完整代码填充。

```typescript
// lib/validation.ts
import { google } from '@ai-sdk/google';
import { generateObject } from 'ai';
import { z } from 'zod';
import { kv } from '@vercel/kv';

// 朱雀AI高频禁用词库（基础版）
const BASE_BLACKLIST = [
  '首先', '其次', '此外', '总之', '综上所述', '你有没有发现',
  '你知道吗', '相关研究表明', '根据数据显示', '家人们谁懂啊',
  '宝子们', '家人们', '值得注意的是', '毫无疑问', '显而易见'
];

// 改进中文分句（支持更多标点）
function splitChineseSentences(text: string) {
  return text.match(/[^。！？；…\n]+[。！？；…\n]?/g) || [text];
}

// JS预计算客观指标
export function computeMetrics(text: string) {
  const sentences = splitChineseSentences(text);
  const lengths = sentences.map(s => s.length);
  const avgLength = lengths.reduce((a, b) => a + b, 0) / lengths.length || 0;
  const maxLen = Math.max(...lengths);
  const minLen = Math.min(...lengths);
  const burstiness = avgLength > 0 ? ((maxLen - minLen) / avgLength) * 100 : 0;
  
  // 黑名单命中（使用词边界避免误伤）
  const blacklistHits = BASE_BLACKLIST.filter(word => 
    new RegExp(`\\b${word}\\b|${word}[。！？；]`).test(text)
  ).length;
  
  const hasShortSentence = lengths.some(l => l < 5);
  const hasLongSentence = lengths.some(l => l > 30);

  return {
    sentenceCount: sentences.length,
    avgLength: Math.round(avgLength),
    burstiness: Math.round(burstiness),
    blacklistHits,
    hasShortSentence,
    hasLongSentence,
  };
}

// 强校验 Schema（补充 position/snippet）
const ZhuqueValidationSchema = z.object({
  score: z.number().describe("综合AI分数，0-100分"),
  isPass: z.boolean().describe("分数<=10则为true"),
  risks: z.array(z.object({
    type: z.enum(["perplexity", "burstiness", "structure", "coherence", "cliche", "emotion"]),
    originalText: z.string(),
    position: z.string().optional(),
    snippet: z.string().optional(),
    suggestion: z.string()
  }))
});

// 核心校验函数（融合客观指标 + LLM推理）
export async function validateAIParagraph(
  paragraph: string,
  exemptions: string[] = [],
  articleId: string = 'default'
) {
  const metrics = computeMetrics(paragraph);
  
  // 缓存当前段落指标（供全局校验使用）
  await kv.set(`article:${articleId}:last_metrics`, metrics, { ex: 3600 });

  const systemPrompt = `
你是1:1复刻腾讯朱雀AI检测逻辑的文本校验专家。

【预计算的客观指标（请严格参考，不可覆盖）】
- 句长爆发性（Burstiness）：${metrics.burstiness}%（人类写作通常>50%）
- 是否有<5字的短句：${metrics.hasShortSentence ? '是' : '否'}
- 是否有>30字的长句：${metrics.hasLongSentence ? '是' : '否'}
- AI高频套话命中次数：${metrics.blacklistHits}次（必须为0）

【核心检测维度】
1. 困惑度替代：结合客观指标，检查是否过度使用高频泛化词汇。段落中应有具象化、场景化或罕见词汇。
2. 爆发性替代：如果客观指标中短句/长句缺失，直接标记为高风险。
3. 语义连贯性：检查是否有自然的思维跳跃（括号补充、口语转折）。完全平滑的逻辑标记为高风险。
4. AI高频套话：如果客观指标中命中次数>0，直接标记为高风险。
5. 结构重复：同一句式/结尾方式在本段内重复出现，标记为高风险。

【豁免规则】
以下用户固定范式特征，绝对不能标记为AI风险：
${exemptions?.join('\n') || '无特殊豁免规则'}

综合AI分数≤10分视为通过。输出严格的JSON格式。
`;

  const { object } = await generateObject({
    model: google('gemini-2.0-flash-exp'), // 2026稳定推荐
    schema: ZhuqueValidationSchema,
    system: systemPrompt,
    prompt: `请校验以下段落：\n\n${paragraph}`,
    temperature: 0.1,
  });

  // 强制修正：如果黑名单命中但LLM给了低分
  if (metrics.blacklistHits > 0 && object.score <= 10) {
    object.score = 35;
    object.isPass = false;
    object.risks.push({
      type: 'cliche',
      originalText: paragraph.slice(0, 50),
      suggestion: '删除AI高频套话'
    });
  }

  return object;
}
```

