### 03_自动修改模块（modify-paragraph）.txt

**文件**：`app/api/writing-agent/modify-paragraph/route.ts`（替换）

```typescript
import { google } from '@ai-sdk/google';
import { generateObject } from 'ai';
import { z } from 'zod';

const ModificationSchema = z.object({
  modifiedText: z.string(),
  explanation: z.string()
});

export async function POST(req: Request) {
  const { originalText, issues, userPersona, modificationType, historyContext } = await req.json();

  let constraintLock = "";
  if (modificationType === 'ai') {
    constraintLock = `【锁定约束】：消除AI特征，但绝对禁止破坏用户的固定范式（如：${userPersona.fixedStructureParadigm || ''}）。禁止改变段落核心主线和排版。`;
  } else {
    constraintLock = `【锁定约束】：修复风格偏差，但绝对禁止为了贴合风格而使句子变得平滑均匀。必须保留原文中的长短句交替和思维跳跃特征。`;
  }

  const historyWarning = historyContext 
    ? `【历史警告】：上次失败原因：${historyContext}。本次必须避开！` : "";

  const systemPrompt = `
你是文本精修专家。仅对风险句子进行局部微调，禁止全段重写。
优先级：消除AI特征 > 修复风格范式 > 修复合规性。
${constraintLock}
${historyWarning}
`;

  const { object } = await generateObject({
    model: google('gemini-2.0-flash-exp'),
    schema: ModificationSchema,
    system: systemPrompt,
    prompt: `【原文】\n${originalText}\n\n【需要修复的问题】\n${JSON.stringify(issues)}`,
    temperature: 0.3,
  });

  // 字数波动超过20%视为重写，丢弃
  const originalLen = originalText.length;
  const modifiedLen = object.modifiedText.length;
  if (Math.abs(modifiedLen - originalLen) / originalLen > 0.2) {
    return Response.json({ error: "MODIFICATION_TOO_LARGE" }, { status: 400 });
  }

  return Response.json(object);
}
```

