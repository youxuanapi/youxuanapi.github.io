// 在主生成路由中，生成每个段落后执行以下校验循环

let currentPara = generatedText;
let aiPass = false, stylePass = false;
let retry = 0;
const MAX_RETRY = 5;

while ((!aiPass || !stylePass) && retry < MAX_RETRY) {
  // Step 1: AI预校验
  const aiRes = await fetch('/api/writing-agent/validate-ai', {
    method: 'POST',
    body: JSON.stringify({ 
      paragraph: currentPara, 
      userStyleExemptions: persona.antiAiExemptList,
      articleId: currentArticleId 
    })
  });
  const aiData = await aiRes.json();
  aiPass = aiData.isPass;

  if (!aiPass) {
    const modRes = await fetch('/api/writing-agent/modify-paragraph', {
      method: 'POST',
      body: JSON.stringify({ 
        originalText: currentPara, 
        issues: aiData.risks, 
        userPersona: persona, 
        modificationType: 'ai',
        historyContext: retry > 0 ? 'AI特征消除失败' : null
      })
    });
    const modData = await modRes.json();
    currentPara = modData.modifiedText;
    retry++;
    continue;
  }

  // Step 2: 风格合并校验
  const styleRes = await fetch('/api/writing-agent/validate-style', {
    method: 'POST',
    body: JSON.stringify({ 
      paragraph: currentPara, 
      persona, 
      outlineContext: outline, 
      previousContent: previousPara 
    })
  });
  const styleData = await styleRes.json();
  stylePass = styleData.isPass;

  if (!stylePass) {
    const modRes = await fetch('/api/writing-agent/modify-paragraph', {
      method: 'POST',
      body: JSON.stringify({ 
        originalText: currentPara, 
        issues: styleData.issues, 
        userPersona: persona, 
        modificationType: 'style',
        historyContext: retry > 0 ? '风格修复失败' : null
      })
    });
    const modData = await modRes.json();
    currentPara = modData.modifiedText;
    retry++;
  }
}

// 存储已生成段落到 KV（用于滑动窗口）
const existingSegments = await kv.get(`article:${articleId}:segments`) || [];
existingSegments.push(currentPara);
await kv.set(`article:${articleId}:segments`, existingSegments, { ex: 3600 });

// 每3段触发增量全局校验
if (existingSegments.length % 3 === 0) {
  const windowRes = await fetch('/api/writing-agent/validate-global-window', {
    method: 'POST',
    body: JSON.stringify({ paragraphs: existingSegments.slice(-3) })
  });
  const windowData = await windowRes.json();
  if (!windowData.passed) {
    // 触发对最后一段的针对性修改（可复用自动修改模块）
  }
}
```

