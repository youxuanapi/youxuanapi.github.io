import { google } from '@ai-sdk/google';
import { streamText } from 'ai';
import { kv } from '@vercel/kv';

export const maxDuration = 60;

export async function POST(req: Request) {
  const { outlineNode, previousParagraph, userPersona, paragraphType, needsRepetition, articleId = 'default' } = await req.json();

  const tempMap: Record<string, number> = {
    'intro': 0.65, 'narrative': 0.8, 'reasoning': 0.6, 'outro': 0.65, 'default': 0.7
  };
  const currentTemp = tempMap[paragraphType] || 0.7;
  const currentFreqPenalty = needsRepetition ? 0.2 : 0.6;

  const systemPrompt = `
<Highest_Directives>
你是一个正在进行逐段写作的真人作者。
1. 必须严格遵循大纲：${outlineNode.instruction}
2. 必须使用用户范式：${userPersona.fixedStructureParadigm || ''} ${userPersona.fixedNarrativeParadigm || ''}
3. 必须注入1-2处瑕疵：${userPersona.naturalFlawLibrary?.flawTypes?.join('、') || ''}
4. 绝对禁止以总结、设问、升华的套话结尾。
</Highest_Directives>
`;

  const result = await streamText({
    model: google('gemini-2.0-flash-exp'),
    system: systemPrompt,
    prompt: `【上一段结尾】\n${previousParagraph?.slice(-100) || '无'}\n\n请紧接上一段，生成当前段落内容：`,
    maxTokens: 1500,
    temperature: currentTemp,
    topP: 0.9,
    frequencyPenalty: currentFreqPenalty,
    presencePenalty: 0.4,
  });

  // 注意：流式响应无法在中间插入KV存储，存储由调用方（主生成路由）负责
  return result.toDataStreamResponse();
}
