// app/api/writing-agent/external-check/route.ts
import { NextResponse } from 'next/server';
import stringSimilarity from 'string-similarity';
import { kv } from '@vercel/kv';

export const maxDuration = 60;

async function callOriginality(text: string, title = 'AI写作智能体扫描') {
  const res = await fetch('https://api.originality.ai/api/v3/scan', {
    method: 'POST',
    headers: { 
      'X-OAI-API-KEY': process.env.ORIGINALITY_KEY!,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      title,
      check_ai: true,
      aiModelVersion: 'multilang',
      content: text,
    })
  });

  if (!res.ok) throw new Error(`Originality v3 failed: ${res.status}`);
  const data = await res.json();
  const aiScore = Math.round((data.results?.ai?.confidence?.AI || 0) * 100);
  return aiScore;
}

async function callGPTZero(text: string) {
  const res = await fetch('https://api.gptzero.me/v2/predict/text', {
    method: 'POST',
    headers: { 
      'x-api-key': process.env.GPTZERO_KEY!,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({ document: text })
  });
  if (!res.ok) throw new Error('GPTZero API failed');
  const data = await res.json();
  return Math.round(data.documents[0].completely_generated_prob * 100);
}

export async function POST(req: Request) {
  try {
    const { currentText, lastCheckedText, lastResult, articleId = 'default' } = await req.json();

    // KV缓存防重复调用
    const cacheKey = `external-check:${articleId}:${currentText.slice(0, 100)}`;
    const cached = await kv.get(cacheKey);
    if (cached) return NextResponse.json({ result: cached });

    // 修改幅度不足30%则复用
    if (lastCheckedText && lastResult) {
      const similarity = stringSimilarity.compareTwoStrings(
        currentText.replace(/[^\p{L}\p{N}]/gu, ''), 
        lastCheckedText.replace(/[^\p{L}\p{N}]/gu, '')
      );
      if (similarity > 0.7) {
        await kv.set(cacheKey, lastResult, { ex: 1800 });
        return NextResponse.json({ message: "复用历史结果", result: lastResult });
      }
    }

    let aiScore = 0, provider = '';
    try {
      aiScore = await callOriginality(currentText);
      provider = 'originality_v3';
    } catch {
      try {
        aiScore = await callGPTZero(currentText);
        provider = 'gptzero';
      } catch {
        return NextResponse.json({ 
          message: "外部API不可用，已降级为内部校验", 
          result: { provider: 'internal', aiScore: 15, isPass: true } 
        });
      }
    }

    const result = { provider, aiScore, isPass: aiScore <= 20 };
    await kv.set(cacheKey, result, { ex: 1800 });
    return NextResponse.json({ result });
  } catch (error) {
    return NextResponse.json({ error: "INTERNAL_SERVER_ERROR" }, { status: 500 });
  }
}
```

